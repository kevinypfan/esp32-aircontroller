# 複製這個檔案為 secrets.yaml 並填入真實值
# secrets.yaml 不會被 git 追蹤（見 .gitignore）
#
# 注意：secrets.yaml 跟 maxe-aircon.yaml 必須放在同一個資料夾

# === WiFi 設定 ===
wifi_ssid: "你的WiFi名稱"
wifi_password: "你的WiFi密碼"

# AP fallback 熱點密碼（當 WiFi 連不上時模組會自己開熱點）
# 至少 8 碼
ap_password: "fallback-password-here"

# === Home Assistant API 加密金鑰 ===
# 在 ESPHome dashboard 編譯時會自動產生，或執行：
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# 把產生的字串貼上來
api_key: "base64-encoded-32-byte-key-here"

# === OTA 韌體更新密碼 ===
# 任意密碼，用於之後 OTA 更新時的驗證
ota_password: "any-password-you-like"
